# enterprise_ai — environment variable template
#
# Copy this file to `.env` (which is gitignored) and fill in your real values.
# Only ANTHROPIC_API_KEY is strictly required, and only for live-API tests
# (`uv run pytest -m api ...`). Everything else has sensible defaults.

# ---------------------------------------------------------------------------
# Required for live-API tests
# ---------------------------------------------------------------------------

# Your Anthropic API key. Get one at https://console.anthropic.com/.
# Without this, all `-m api` tests are auto-skipped (the rest of the suite
# still runs fine).
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Optional — Anthropic SDK overrides
# ---------------------------------------------------------------------------

# Override the default model for live-API runs.
# Default: claude-haiku-4-5
# Setting this to anything that doesn't start with "claude-haiku" will
# ABORT the test session unless ALLOW_NON_HAIKU=1 is also set (cost guard).
# ANTHROPIC_MODEL=claude-haiku-4-5

# Per-pytest-session cap on total Anthropic API calls.
# Default: 50  (5 calls/scenario × 4 scenarios + headroom)
# Raise this only if you know why — runaway loops can burn budget fast.
# ANTHROPIC_MAX_CALLS=50

# Bypass the Haiku-only safety check.
# Set to "1" to permit Sonnet/Opus runs (each scenario fans out to ~5 agent
# calls, so non-Haiku runs cost noticeably more).
# ALLOW_NON_HAIKU=1

# ---------------------------------------------------------------------------
# Optional — terminal output
# ---------------------------------------------------------------------------

# Standard convention: any non-empty value disables ANSI color codes in
# test-runner console output.
# NO_COLOR=1
